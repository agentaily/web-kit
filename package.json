{
  "name": "@agentaily/web-kit",
  "version": "0.1.1",
  "description": "跨产品共享的浏览器运行时库 —— 主题 + 国际化 + 跨子域 cookie 持久化(非视觉运行时)。",
  "type": "module",
  "license": "MIT",
  "author": "agentaily",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentaily/web-kit.git"
  },
  "homepage": "https://github.com/agentaily/web-kit#readme",
  "bugs": {
    "url": "https://github.com/agentaily/web-kit/issues"
  },
  "keywords": [
    "react",
    "theme",
    "dark-mode",
    "i18n",
    "cookie",
    "persistence",
    "ssr",
    "agentaily"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "lefthook install"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "lefthook": "^1.10.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
